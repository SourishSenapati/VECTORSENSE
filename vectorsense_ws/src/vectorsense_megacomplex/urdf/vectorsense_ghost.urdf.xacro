<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="vectorsense_drone">

  <!-- THE GHOST CORE: Mathematically Perfect Physics Skeleton -->
  <link name="base_link">
    <!-- PHYSICS CORE: Zero-Visual, Perfectly Symmetric Intertials -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.5"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.06"/>
    </inertial>
    
    <!-- COLLISION CORE: Primitive-only to prevent mesh shears -->
    <collision name="base_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.1"/>
      </geometry>
    </collision>

    <!-- VISUAL SKINS: Weightless CAD layers (No Collision / No Inertial) -->
    <visual name="skin_base">
      <geometry>
        <mesh filename="package://vectorsense_megacomplex/meshes/DroneFYDPBase.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    
    <visual name="skin_xbeam">
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vectorsense_megacomplex/meshes/Xbeam.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <visual name="skin_beam180">
      <origin xyz="0 0 0.05" rpy="0 0 1.5708"/>
      <geometry>
        <mesh filename="package://vectorsense_megacomplex/meshes/180beam.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <visual name="skin_top_plate">
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vectorsense_megacomplex/meshes/top_plate.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <!-- MOTORS: Exact Symmetry (Hexacopter configuration) -->
  <xacro:macro name="motor" params="name x y index direction">
    <link name="motor_${name}">
      <visual>
        <geometry>
          <mesh filename="package://vectorsense_megacomplex/meshes/motor_attachment.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="motor_${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="motor_${name}"/>
      <origin xyz="${x} ${y} 0.08" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

    <gazebo>
      <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
        <robotNamespace>vectorsense</robotNamespace>
        <jointName>motor_${name}_joint</jointName>
        <linkName>motor_${name}</linkName>
        <turningDirection>${direction}</turningDirection>
        <timeConstantUp>0.0125</timeConstantUp>
        <timeConstantDown>0.025</timeConstantDown>
        <maxRotVelocity>1500</maxRotVelocity>
        <motorConstant>8.54858e-04</motorConstant>
        <momentConstant>0.016</momentConstant>
        <commandSubTopic>command/motor_speed</commandSubTopic>
        <motorNumber>${index}</motorNumber>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
        <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
        <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      </plugin>
    </gazebo>
  </xacro:macro>

  <!-- Hexacopter Arms (60 deg separation) -->
  <xacro:motor name="front_right" x="0.3" y="-0.17" index="0" direction="ccw"/>
  <xacro:motor name="right" x="0" y="-0.34" index="1" direction="cw"/>
  <xacro:motor name="back_right" x="-0.3" y="-0.17" index="2" direction="ccw"/>
  <xacro:motor name="back_left" x="-0.3" y="0.17" index="3" direction="cw"/>
  <xacro:motor name="left" x="0" y="0.34" index="4" direction="ccw"/>
  <xacro:motor name="front_left" x="0.3" y="0.17" index="5" direction="cw"/>

  <!-- SENSING PAYLOAD -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.05" length="0.05"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <gazebo reference="lidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.2</min>
          <max>30.0</max>
        </range>
      </lidar>
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-multicopter-velocity-control-system" name="gz::sim::systems::MulticopterVelocityControl">
      <robotNamespace>vectorsense</robotNamespace>
      <commandSubTopic>cmd_vel</commandSubTopic>
      <enableAngleControl>true</enableAngleControl>
      <enableVelocityControl>true</enableVelocityControl>
      <maximumLinearVelocity>15.0</maximumLinearVelocity>
      <maximumAngularVelocity>5.0</maximumAngularVelocity>
    </plugin>
    
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
    </plugin>

    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
    </plugin>
  </gazebo>

</robot>
