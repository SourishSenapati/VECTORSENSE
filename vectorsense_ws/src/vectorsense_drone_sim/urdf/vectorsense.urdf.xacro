<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="vectorsense_drone">

  <!-- Materials -->
  <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
  <material name="red"><color rgba="0.8 0.0 0.0 1.0"/></material>

  <!-- base_link -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://vectorsense_drone_sim/meshes/DroneFYDPBase.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://vectorsense_drone_sim/meshes/DroneFYDPBase.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <!-- Rigid Attachments -->
  <xacro:macro name="rigid_attachment" params="name mesh_file color">
    <link name="${name}">
      <visual>
        <geometry>
          <mesh filename="package://vectorsense_drone_sim/meshes/${mesh_file}" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${color}"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://vectorsense_drone_sim/meshes/${mesh_file}" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:rigid_attachment name="xbeam" mesh_file="Xbeam.stl" color="dark_grey"/>
  <xacro:rigid_attachment name="beam_180" mesh_file="180beam.stl" color="dark_grey"/>
  <xacro:rigid_attachment name="beam_mechanism" mesh_file="beam_mechanism.stl" color="blue"/>
  <xacro:rigid_attachment name="mechanism_fix" mesh_file="mechanisam_fix.stl" color="blue"/>
  <xacro:rigid_attachment name="top_plate" mesh_file="top_plate.stl" color="dark_grey"/>

  <!-- Dynamic Motors -->
  <xacro:macro name="motor" params="name x y">
    <link name="motor_${name}">
      <visual>
        <geometry>
          <mesh filename="package://vectorsense_drone_sim/meshes/motor_attachment.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="red"/>
      </visual>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
      </inertial>
    </link>
    <joint name="motor_${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="motor_${name}"/>
      <origin xyz="${x} ${y} 0.05" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:motor name="front_right" x="0.2" y="-0.2"/>
  <xacro:motor name="front_left" x="0.2" y="0.2"/>
  <xacro:motor name="back_right" x="-0.2" y="-0.2"/>
  <xacro:motor name="back_left" x="-0.2" y="0.2"/>

  <!-- Gazebo Plugins -->
  <gazebo>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <robotNamespace>vectorsense</robotNamespace>
      <jointName>motor_front_right_joint</jointName>
      <linkName>motor_front_right</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>800</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin filename="gz-sim-multicopter-velocity-control-system" name="gz::sim::systems::MulticopterVelocityControl">
      <robotNamespace>vectorsense</robotNamespace>
      <commandSubTopic>cmd_vel</commandSubTopic>
      <enableAngleControl>true</enableAngleControl>
      <enableVelocityControl>true</enableVelocityControl>
      <maximumLinearVelocity>10.0</maximumLinearVelocity>
      <maximumAngularVelocity>5.0</maximumAngularVelocity>
    </plugin>
  </gazebo>

</robot>
