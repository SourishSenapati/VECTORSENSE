solid top_plate.stl
  facet normal 0 0 0
    outer loop
      vertex 0 0 0
      vertex 0.15 0 0
      vertex 0.15 0.15 0
    endloop
  endfacet
  facet normal 0 0 0
    outer loop
      vertex 0 0 0
      vertex 0.15 0.15 0
      vertex 0 0.15 0
    endloop
  endfacet
  facet normal 0 0 0
    outer loop
      vertex 0 0 0.01
      vertex 0.15 0 0.01
      vertex 0.15 0.15 0.01
    endloop
  endfacet
  facet normal 0 0 0
    outer loop
      vertex 0 0 0.01
      vertex 0.15 0.15 0.01
      vertex 0 0.15 0.01
    endloop
  endfacet
endsolid top_plate.stl
